# Vercel
# =============================================================================
.vercel
.fakehome/

# =============================================================================
# Tooling-generated artifacts (kimchi / understand-anything)
# =============================================================================
# .kimchi/ contains generated audit and lighthouse reports; .understand-anything/
# contains generated knowledge-graph data. These are produced by the project
# tooling and regenerated on demand — do not commit fresh generations.
/.kimchi/*
!/.kimchi/docs/
/.understand-anything/

# Refactor backup reference / graphify output (do not bundle/lint)
.graphifyignore
graphify-out/*

# =============================================================================
# Go
# =============================================================================
/backend/vendor/

